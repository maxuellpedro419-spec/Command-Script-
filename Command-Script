local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TextChatService = game:GetService("TextChatService")

local player = Players.LocalPlayer

--========================
-- EXECUTE SOUND
--========================

pcall(function()
	local sound = Instance.new("Sound")
	sound.Parent = workspace
	sound.SoundId = "rbxassetid://138118203571469"
	sound.Volume = 3
	sound:Play()
	game:GetService("Debris"):AddItem(sound,10)
end)

--========================
-- VARIÁVEIS
--========================

local infiniteJump = false
local noclip = false

local currentSpeed = 16

local spinning = false
local spinSpeed = 20
local spinObject = nil

local espEnabled = false
local espList = {}

local tpWalk = false
local tpWalkDistance = 3

-- FLY & VIEW
local camera = workspace.CurrentCamera
local viewTarget = nil

local controls = require(
	player.PlayerScripts:WaitForChild("PlayerModule")
):GetControls()

local flying = false
local flySpeed = 50 -- Velocidade Inicial padrão

local bv
local bg

--========================
-- SPEED
--========================

local function applySpeed()
	local char = player.Character
	if char and char:FindFirstChild("Humanoid") then
		char.Humanoid.WalkSpeed = currentSpeed
	end
end

--========================
-- FLY
--========================

local function startFly()
	local char = player.Character
	if not char then return end

	local root = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")

	if not root or not hum then return end

	flying = true

	if bv then bv:Destroy() end
	if bg then bg:Destroy() end

	bg = Instance.new("BodyGyro")
	bg.Parent = root
	bg.P = 9e4
	bg.MaxTorque = Vector3.new(9e9,9e9,9e9)
	bg.CFrame = root.CFrame

	bv = Instance.new("BodyVelocity")
	bv.Parent = root
	bv.MaxForce = Vector3.new(9e9,9e9,9e9)
	bv.Velocity = Vector3.new(0,0,0)

	hum.PlatformStand = true

	task.spawn(function()
		while flying and char.Parent do
			RunService.RenderStepped:Wait()
			local moveVector = controls:GetMoveVector()
			if moveVector.Magnitude > 0 then
				local direction = (camera.CFrame.LookVector * -moveVector.Z) + (camera.CFrame.RightVector * moveVector.X)
				bv.Velocity = direction * flySpeed
			else
				bv.Velocity = Vector3.new(0,0,0)
			end
			bg.CFrame = camera.CFrame
		end
	end)
end

local function stopFly()
	flying = false
	local char = player.Character
	if char and char:FindFirstChildOfClass("Humanoid") then
		char:FindFirstChildOfClass("Humanoid").PlatformStand = false
	end
	if bv then bv:Destroy(); bv = nil end
	if bg then bg:Destroy(); bg = nil end
end

--========================
-- VIEW / UNVIEW
--========================

RunService.RenderStepped:Connect(function()
    if viewTarget and viewTarget.Character and viewTarget.Character:FindFirstChild("Humanoid") then
        camera.CameraSubject = viewTarget.Character.Humanoid
    else
        if player.Character and player.Character:FindFirstChild("Humanoid") and not viewTarget then
            camera.CameraSubject = player.Character.Humanoid
        end
    end
end)

--========================
-- TP TOOL
--========================

local tpTool = nil

local function createTPTool()
	if tpTool then tpTool:Destroy() end

	tpTool = Instance.new("Tool")
	tpTool.Name = "TP Tool"
	tpTool.RequiresHandle = false
	tpTool.CanBeDropped = false

	tpTool.Activated:Connect(function()
		local mouse = player:GetMouse()
		local char = player.Character

		if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
			local root = char.HumanoidRootPart
			root.Velocity = Vector3.new(0,0,0)
			local targetPos = mouse.Hit.Position + Vector3.new(0, 3, 0)
			root.CFrame = CFrame.new(targetPos, targetPos + Vector3.new(camera.CFrame.LookVector.X, 0, camera.CFrame.LookVector.Z))
		end
	end)

	tpTool.Parent = player.Backpack
end

--========================
-- SPIN
--========================

local function startSpin()
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		local root = char.HumanoidRootPart
		if spinObject then spinObject:Destroy() end
		spinObject = Instance.new("BodyAngularVelocity")
		spinObject.Parent = root
		spinObject.MaxTorque = Vector3.new(0, math.huge, 0)
		spinObject.AngularVelocity = Vector3.new(0, spinSpeed, 0)
		spinning = true
	end
end

local function stopSpin()
	spinning = false
	if spinObject then
		spinObject:Destroy()
		spinObject = nil
	end
end

--========================
-- NOCLIP
--========================

RunService.Stepped:Connect(function()
	if noclip and player.Character then
		for _,v in pairs(player.Character:GetDescendants()) do
			if v:IsA("BasePart") then v.CanCollide = false end
		end
	end
end)

--========================
-- TPWALK
--========================

RunService.RenderStepped:Connect(function()
	if tpWalk and player.Character then
		local character = player.Character
		local humanoid = character:FindFirstChild("Humanoid")
		local root = character:FindFirstChild("HumanoidRootPart")
		if humanoid and root then
			if humanoid.MoveDirection.Magnitude > 0 then
				root.CFrame = root.CFrame + (humanoid.MoveDirection * tpWalkDistance)
			end
		end
	end
end)

--========================
-- INFINITE JUMP
--========================

UIS.JumpRequest:Connect(function()
	if infiniteJump and player.Character then
		local hum = player.Character:FindFirstChild("Humanoid")
		if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
	end
end)

--========================
-- ESP
--========================

local function clearESP()
	for _,v in pairs(espList) do if v then v:Destroy() end end
	espList = {}
end

local function makeESP(plr)
	if plr == player then return end
	local function apply(char)
		if not espEnabled then return end
		local highlight = Instance.new("Highlight")
		highlight.FillColor = Color3.fromRGB(170,0,255)
		highlight.OutlineColor = Color3.fromRGB(255,255,255)
		highlight.FillTransparency = 0.5
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.Parent = char
		table.insert(espList, highlight)
	end
	if plr.Character then apply(plr.Character) end
	plr.CharacterAdded:Connect(function(char)
		task.wait(1)
		apply(char)
	end)
end

local function enableESP()
	espEnabled = true
	for _,plr in pairs(Players:GetPlayers()) do makeESP(plr) end
end

local function disableESP()
	espEnabled = false
	clearESP()
end

--========================
-- FIND PLAYER HELPER
--========================

local function findPlayer(name)
	name = string.lower(name)
	for _,plr in pairs(Players:GetPlayers()) do
		local username = string.lower(plr.Name)
		local displayname = string.lower(plr.DisplayName)
		if string.sub(username,1,#name) == name or string.sub(displayname,1,#name) == name then
			return plr
		end
	end
end

--========================
-- COMMANDS
--========================

local function handleCommand(msg)
	msg = string.lower(msg)

	if msg == "/infinitejump" then infiniteJump = true end
	if msg == "/uninfinitejump" then infiniteJump = false end

	if string.sub(msg,1,7) == "/speed " then
		local num = tonumber(string.sub(msg,8))
		if num then currentSpeed = num; applySpeed() end
	end
	if msg == "/unspeed" then currentSpeed = 16; applySpeed() end

	if msg == "/noclip" then noclip = true end
	if msg == "/unnoclip" then
		noclip = false
		if player.Character then
			for _,v in pairs(player.Character:GetDescendants()) do
				if v:IsA("BasePart") then v.CanCollide = true end
			end
		end
	end

	if msg == "/spin" then startSpin() end
	if string.sub(msg,1,6) == "/spin " then
		local num = tonumber(string.sub(msg,7))
		if num then spinSpeed = num; startSpin() end
	end
	if msg == "/unspin" then stopSpin() end

	if msg == "/esp" then enableESP() end
	if msg == "/unesp" then disableESP() end

	if string.sub(msg,1,6) == "/goto " then
		local target = string.sub(msg,7)
		local found = findPlayer(target)
		if found and found.Character and found.Character:FindFirstChild("HumanoidRootPart") then
			player.Character.HumanoidRootPart.CFrame = found.Character.HumanoidRootPart.CFrame + Vector3.new(2,0,2)
		end
	end

	-- VIEW COMMANDS
	if string.sub(msg,1,6) == "/view " then
		local target = string.sub(msg,7)
		viewTarget = findPlayer(target)
	end
	if msg == "/unview" then
		viewTarget = nil
		if player.Character and player.Character:FindFirstChild("Humanoid") then
			camera.CameraSubject = player.Character.Humanoid
		end
	end

	if msg == "/tpwalk" then tpWalk = true end
	if msg == "/untpwalk" then tpWalk = false end

	-- FLY (MODIFICADO PARA SUPORTAR VELOCIDADE)
	if msg == "/fly" then
		flySpeed = 50
		startFly()
	end
	if string.sub(msg,1,5) == "/fly " then
		local num = tonumber(string.sub(msg,6))
		if num then
			flySpeed = num
			startFly()
		end
	end
	if msg == "/unfly" then stopFly() end

	if msg == "/tptool" then createTPTool() end
end

--========================
-- CHAT FIX
--========================

if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
	TextChatService.SendingMessage:Connect(function(message)
		handleCommand(message.Text)
	end)
else
	player.Chatted:Connect(handleCommand)
end

--========================
-- RESPAWN
--========================

player.CharacterAdded:Connect(function()
	task.wait(1)
	applySpeed()
	if spinning then startSpin() end
	if flying then startFly() end
	-- Se estava em view, a câmera volta ao alvo automaticamente pelo RenderStepped
end)

applySpeed()
